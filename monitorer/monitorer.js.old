print('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'cyan')
console.log('')
print(`  📊 Monitoring:`, 'yellow')
print(`     ATR: ${config.atrUrl}`, 'blue')
print(`     Levels: ${config.levelsUrl}`, 'blue')
print(`     Bot: ${config.botUrl}`, 'blue')
